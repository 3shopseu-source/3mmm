# ─────────────────────────────────────────
# 3Market Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────

# Stripe (get from dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Your frontend URL (for CORS + redirect URLs)
FRONTEND_URL=https://your-3market-site.com

# Port (Railway/Render set this automatically)
PORT=3001

# Optional: Supabase service key (for server-side DB ops)
SUPABASE_URL=https://duyjcaqvdhndfpoeuhui.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_KEY_HERE
